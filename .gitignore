__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Node
node_modules/
dist/
.vite/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Temp
*.tmp
*.csv

# Runtime data
backend/var/
# 但 var/skills/ 下是可装载 skill 的"代码"（按目录即插件的格式），需要纳入版本控制
!backend/var/skills/
!backend/var/skills/**
# var/skills 下每个 skill 的 learning/snapshots 仍然是运行时数据，不入库
backend/var/skills/*/learning/snapshots/
backend/var/skills/*/learning/reports/
*.log
backend/scripts/smoke_results/

# Tooling caches / agent worktrees
.claude/
.playwright-mcp/

# Build artifacts
*.tsbuildinfo
*.corrupt.bak

# QA screenshots & temp browser data
.tmp-qa-shots/
.tmp-edge-*/
*.png
